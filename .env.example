# Copy to .env and fill in. NEVER commit .env.
# Telegram bot token from @BotFather
TELEGRAM_TOKEN=

# Gemini API key from aistudio.google.com/apikey (free tier)
GEMINI_API_KEY=

# GitHub fine-grained PAT with Contents read/write on the vault repo
GITHUB_TOKEN=

# Your Obsidian vault repo, e.g. rogerpurnomo/roger-brain
GITHUB_REPO=

# Branch the vault lives on
GITHUB_BRANCH=main

# Your numeric Telegram user ID (from @userinfobot). Only this user can use the bot.
ALLOWED_USER_ID=

# Optional — override the model (defaults to gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash
